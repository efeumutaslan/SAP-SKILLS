{
  "_version": "1.58.0",
  "sap.app": {
    "id": "{{APP_NAMESPACE}}",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": { "version": "1.0.0" },
    "title": "{{i18n>appTitle}}",
    "description": "{{i18n>appDescription}}",
    "resources": "resources.json",
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/{{SERVICE_PATH}}/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0",
          "localUri": "localService/metadata.xml"
        }
      }
    },
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.11.3"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": { "icon": "sap-icon://product" },
    "deviceTypes": { "desktop": true, "tablet": true, "phone": true }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "rootView": {
      "viewName": "{{APP_NAMESPACE}}.view.App",
      "type": "XML",
      "async": true,
      "id": "App"
    },
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.ushell": {},
        "sap.suite.ui.generic.template": {},
        "sap.ui.comp": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": { "bundleName": "{{APP_NAMESPACE}}.i18n.i18n" }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": { "css": [{ "uri": "css/style.css" }] },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "{{APP_NAMESPACE}}.view",
        "controlAggregation": "pages",
        "controlId": "App",
        "clearControlAggregation": false
      },
      "routes": [
        {
          "name": "worklist",
          "pattern": "",
          "target": ["worklist"]
        },
        {
          "name": "object",
          "pattern": "{{ENTITY_SET}}/{id}",
          "target": ["object"]
        }
      ],
      "targets": {
        "worklist": {
          "viewType": "XML",
          "viewName": "Worklist",
          "viewLevel": 1
        },
        "object": {
          "viewType": "XML",
          "viewName": "Object",
          "viewLevel": 2
        }
      }
    },
    "contentDensities": { "compact": true, "cozy": true }
  }
}
